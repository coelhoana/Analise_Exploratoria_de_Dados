# Histograma - Mortalidade Infantil
# ==========================================
ggplot(df_limpo, aes(x = mortalidadeInfantil_obitosPor1000)) +
geom_histogram(
bins = 10,
fill = "#E15759",
color = "black",
alpha = 0.8
) +
scale_x_continuous(
breaks = pretty_breaks(n = 8)
) +
labs(
title = "Distribuição da Mortalidade Infantil",
x = "Óbitos por mil nascidos vivos",
y = "Quantidade de Municípios"
) +
theme_minimal() +
theme(
plot.title = element_text(
hjust = 0.5,
face = "bold",
size = 14
),
axis.title = element_text(face = "bold")
)
# ==========================================
# Histograma - PIB per Capita
# ==========================================
ggplot(df_limpo, aes(x = pib_percapita)) +
geom_histogram(
bins = 15,
fill = "#F28E2B",
color = "black",
alpha = 0.8
) +
scale_x_continuous(
labels = label_number(big.mark = ".", decimal.mark = ","),
breaks = pretty_breaks(n = 8)
) +
labs(
title = "Distribuição do PIB per Capita",
x = "PIB per Capita (R$)",
y = "Quantidade de Municípios"
) +
theme_minimal() +
theme(
plot.title = element_text(
hjust = 0.5,
face = "bold",
size = 14
),
axis.title = element_text(face = "bold"),
axis.text.x = element_text(angle = 45, hjust = 1)
)
# 2. Preparação e Limpeza dos Dados
# Substitua 'dados_ibge' pelo nome do seu dataframe carregado
df_numerico <- df_limpo %>%
# Seleciona as colunas usando termos-chave (evita ter que digitar as tags HTML inteiras)
select(
IDHM = contains("IDHM"),
Escolarizacao = contains("Escolarização"),
Mortalidade = contains("Mortalidade")
) %>%
# Truta strings/caracteres especiais e converte tudo para numérico
mutate(
across(everything(), ~ as.numeric(na_if(as.character(.), "-")))
) %>%
# Transforma o dado no formato longo necessário para o seu facet_wrap
pivot_longer(
cols = everything(),
names_to = "variavel",
values_to = "valor"
) %>%
# Remove os valores ausentes para o boxplot ficar limpo
drop_na(valor)
# 3. O seu Boxplot customizado
ggplot(df_numerico, aes(y = valor)) +
geom_boxplot(fill = "#8e44ad", alpha = 0.7, width = 0.5) +
facet_wrap(~ variavel, scales = "free") +
scale_y_continuous(labels = label_number(big.mark = ".", decimal.mark = ",")) +
theme_minimal() +
labs(
title = "Dispersão e Outliers (Boxplots) de Indicadores Municipais",
subtitle = "Análise de IDHM, Escolarização e Mortalidade Infantil",
y = "Valor"
) +
theme(
axis.text.x = element_blank(),
axis.title.x = element_blank(),
axis.ticks.x = element_blank(),
strip.text = element_text(face = "bold", size = 11),
plot.title = element_text(face = "bold", size = 14),
panel.grid.major.x = element_blank() # Remove linhas verticais desnecessárias
)
top10_area <- df_limpo |>
slice_max(areaTerritorial_km2, n = 10) |>
select(municipio, areaTerritorial_km2, populacao_ultimoCenso, densidadeDemografica, idhm, pib_percapita) |>
arrange(desc(areaTerritorial_km2))
top10_area |>
mutate(
areaTerritorial_km2 = label_comma(big.mark = ".")(round(areaTerritorial_km2, 1)),
populacao_ultimoCenso = label_comma(big.mark = ".")(populacao_ultimoCenso),
densidadeDemografica = round(densidadeDemografica, 2),
pib_per_capita = label_dollar(prefix = "R$ ", big.mark = ".", decimal.mark = ",")(round(pib_percapita))
) |>
rename(
Município        = municipio,
`Área (km²)`     = areaTerritorial_km2,
`Pop. 2022`      = populacao_ultimoCenso,
`Dens. (hab/km²)`= densidadeDemografica,
IDHM             = idhm,
`PIB pc (R$)`    = pib_percapita
) |>
kable(caption = "10 municípios com maior área territorial (MG, 2025)",
booktabs = TRUE, align = "lrrrrr") |>
kable_styling(latex_options = c("hold_position", "scale_down"))
# Par 1: Mortalidade infantil x IDHM (saúde x desenvolvimento humano)
ggplot(df_limpo, aes(x = idhm, y = mortalidadeInfantil_obitosPor1000)) +
geom_point(alpha = 0.5, color = "steelblue") +
geom_smooth(method = "loess", color = "darkred", se = FALSE) +
theme_minimal() +
labs(title = "Mortalidade infantil x IDHM",
x = "IDHM", y = "Mortalidade infantil (óbitos/mil nasc. vivos)")
formato_br <- label_number(big.mark = ".", decimal.mark = ",")
variaveis_cor <- df_limpo |>
select(
areaTerritorial_km2, populacao_ultimoCenso, densidadeDemografica, escolarizacao_6a14,
idhm, mortalidadeInfantil_obitosPor1000, total_ReceitasBrutas, total_DespesasBrutas, pib_percapita
) |>
rename(
`Área`         = areaTerritorial_km2,
`Pop.`         = populacao_ultimoCenso,
`Dens. Demo.`  = densidadeDemografica,
`Escolar.`     = escolarizacao_6a14,
IDHM           = idhm,
`Mort. Inf.`   = mortalidadeInfantil_obitosPor1000,
`Receita`      = total_ReceitasBrutas,
`Despesa`      = total_DespesasBrutas,
`PIB pc`       = pib_percapita
)
cor_matrix <- cor(variaveis_cor, method = "spearman", use = "pairwise.complete.obs")
#| fig-height: 6
corrplot(cor_matrix,
method    = "color",
type      = "upper",
order     = "hclust",
tl.cex    = 0.85,
tl.col    = "black",
addCoef.col = "black",
number.cex  = 0.65,
col       = colorRampPalette(c(pal_red, "white", pal_blue))(200),
title     = "Matriz de Correlação de Spearman",
mar       = c(0, 0, 2, 0))
#| fig-height: 6
corrplot(cor_matrix,
method    = "color",
type      = "upper",
order     = "hclust",
tl.cex    = 0.85,
