ggplot(aes(x = municipio, y = area_km2, fill = idhm)) +
geom_col(width = 0.7) +
scale_fill_gradient(low = "#d73027", high = "#1a9850",
name = "IDHM", limits = c(0.5, 0.85)) +
scale_y_continuous(labels = label_comma(big.mark = ".")) +
