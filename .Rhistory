tl.cex    = 0.85,
tl.col    = "black",
addCoef.col = "black",
number.cex  = 0.65,
col       = colorRampPalette(c(pal_red, "white", pal_blue))(200),
title     = "Matriz de Correlação de Spearman",
mar       = c(0, 0, 2, 0))
#| fig-height: 6
corrplot(cor_matrix,
method    = "color",
type      = "upper",
order     = "hclust",
tl.cex    = 0.85,
tl.col    = "black",
addCoef.col = "black",
number.cex  = 0.65,
col       = colorRampPalette(c(pal_red, "white", pal_blue))(200),
title     = "Matriz de Correlação de Spearman",
mar       = c(0, 0, 2, 0))
cor_df <- as.data.frame(as.table(cor_matrix)) |>
filter(as.character(Var1) < as.character(Var2)) |>
rename(Var_A = Var1, Var_B = Var2, `Spearman ρ` = Freq) |>
arrange(desc(abs(`Spearman ρ`))) |>
head(10)
cor_df |>
mutate(`Spearman ρ` = round(`Spearman ρ`, 3)) |>
kable(caption = "Top 10 pares com maior correlação de Spearman (valor absoluto)",
booktabs = TRUE) |>
kable_styling(latex_options = "hold_position")
top10_area |>
